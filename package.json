{
  "name": "aiops",
  "description": "Local Sandcastle orchestration for allowlisted GitLab and GitHub repositories.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "sandcastle": "tsx main.ts",
    "sandcastle:fix-failed-review-requests": "tsx main.ts fix-failed-review-requests",
    "sandcastle:build-image": "sandcastle docker build-image --image-name sandcastle:aiops --dockerfile Dockerfile",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.5.10",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
